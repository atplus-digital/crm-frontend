{
	"name": "crm-atplus",
	"private": true,
	"type": "module",
	"imports": {
		"#/*": "./src/*"
	},
	"scripts": {
		"dev": "vite dev",
		"prepare": "husky",
		"test": "vitest run",
		"test:scripts": "vitest run --config scripts/vitest.config.ts",
		"build": "vite build",
		"start": "node dist",
		"biome:fix": "biome check --write",
		"format:md": "pnpm dlx prettier --write \"**/*.{md,mdx}\" --log-level=warn --no-error-on-unmatched-pattern  --cache",
		"knip": "knip",
		"knip:prod": "knip --production",
		"knip:silent": "knip --production --exclude dependencies --no-config-hints",
		"lint:fix": "pnpm biome:fix && pnpm format:md",
		"typecheck": "tsc --noEmit",
		"lint-staged": "lint-staged",
		"generate": "tsx scripts/generators/src/index.ts",
		"generate:types": "pnpm generate --types",
		"generate:requests": "pnpm generate --requests",
		"analyze-bundle": "pnpx vite-bundle-analyzer",
		"ixc:audit": "tsx scripts/nocobase/ixc-schema-audit/index.ts"
	},
	"dependencies": {
		"@base-ui/react": "^1.4.1",
		"@fontsource-variable/geist": "^5.2.8",
		"@hookform/resolvers": "^5.2.2",
		"@nocobase/sdk": "^2.0.46",
		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-tooltip": "^1.2.8",
		"@t3-oss/env-core": "^0.13.11",
		"@tailwindcss/vite": "^4.2.4",
		"@tanstack/react-query": "^5.100.6",
		"@tanstack/react-query-devtools": "^5.100.6",
		"@tanstack/react-store": "^0.11.0",
		"@tanstack/react-table": "^8.21.3",
		"@tanstack/store": "^0.11.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"date-fns": "^4.1.0",
		"lucide-react": "^1.14.0",
		"nuqs": "^2.8.9",
		"radix-ui": "^1.4.3",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"react-hook-form": "^7.74.0",
		"react-router": "^7.14.2",
		"shadcn": "^4.6.0",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.2.4",
		"tw-animate-css": "^1.4.0",
		"usehooks-ts": "^3.1.1",
		"zod": "^4.4.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.13",
		"@types/jsdom": "^28.0.1",
		"@types/node": "^25.6.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/coverage-v8": "4.1.5",
		"dotenv": "^17.4.2",
		"husky": "^9.1.7",
		"jsdom": "^29.1.1",
		"knip": "^6.9.0",
		"lint-staged": "^16.4.0",
		"listr2": "^10.2.1",
		"test-staged": "^1.1.11",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.10",
		"vite-bundle-analyzer": "^1.3.8",
		"vitest": "^4.1.5"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"lightningcss",
			"msw",
			"protobufjs"
		]
	}
}
