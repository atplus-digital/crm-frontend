{
	"$schema": "https://unpkg.com/knip@6/schema-jsonc.json",
	"tags": [
		"-lintignore"
	],

	"entry": [
		"src/routes/router.tsx",
		"scripts/**/index.ts"
	],
	"project": [
		"src/**/*.ts",
		"src/**/*.tsx",
		"scripts/**/*.ts",
		"src/**/*.css"
	],
	"rules": {
		"exports": "warn",
		"types": "warn",
		"dependencies": "warn",
		"devDependencies": "warn",
		"files": "warn",
		"unlisted": "warn"
	},
	"ignore": ["src/generated/**", "src/components/ui/**"],
	"ignoreDependencies": [],
	"ignoreExportsUsedInFile": true
}
