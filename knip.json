{
	"$schema": "https://unpkg.com/knip@6/schema-jsonc.json",
	"tags": ["-lintignore"],

	"entry": [
		"src/routes/router.tsx",
		"scripts/**/index.ts",
		"src/routes/router.tsx!",
		"scripts/**/index.ts!"
	],
	"project": [
		"src/**/*.ts",
		"src/**/*.tsx",
		"scripts/**/*.ts",
		"src/**/*.ts!",
		"src/**/*.tsx!",
		"scripts/**/*.ts!"
	],
	"rules": {
		"exports": "warn",
		"types": "warn",
		"dependencies": "warn",
		"devDependencies": "warn",
		"files": "warn",
		"unlisted": "warn"
	},
	"ignore": [
		".agents/**",
		"src/generated/**",
		"src/components/ui/**",
		"scripts/generators/src/lib/pipeline/reports.ts",
		"src/features/custom-requests/**",
		"src/features/auth/permissions/hooks.ts",
		"src/features/auth/permissions/matchers.ts"
	],
	"ignoreDependencies": [
		"@fontsource-variable/geist",
		"@radix-ui/react-slot",
		"@radix-ui/react-tooltip",
		"shadcn",
		"tailwindcss",
		"tw-animate-css",
		"cmdk"
	]
}
